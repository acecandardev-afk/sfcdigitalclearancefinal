generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PreClearanceGate {
  faculty
  cmo
  guidance
}

enum Role {
  student
  employee
  signatory
  superadmin
  faculty_admin
  hr_admin
}

enum RequirementKind {
  document
  physical
  office
}

enum ExtensionStatus {
  pending
  approved
  rejected
}

enum ClearanceStatus {
  pending
  in_progress
  approved
  rejected
}

enum SignatureStatus {
  pending
  in_progress
  approved
  rejected
}

enum SignatoryGroup {
  standard
  authority
}

/// Who may fill which line on the institutional Section III (certification) form.
enum InstitutionalCertificationRole {
  none
  preparer
  hrmdo
  president
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  roles         UserRole[]
  profile       Profile?
  signatory     Signatory?

  clearanceRequests ClearanceRequest[]
  studentAssignments StudentSignatoryAssignment[]
  activityLogs ActivityLog[]
  notifications Notification[]

  institutionalClearances         InstitutionalClearance[]      @relation("InstitutionalRequester")
  institutionalItemApprovals      InstitutionalClearanceItem[]  @relation("InstitutionalItemApprover")
  institutionalFilesUploaded     InstitutionalClearanceFile[]  @relation("InstitutionalFileUploader")
  clearanceExtensionRequests     ClearancePeriodExtension[]    @relation("ExtensionStudent")
  clearanceExtensionReviews      ClearancePeriodExtension[]    @relation("ExtensionReviewer")
  officeRequirementVerifications   ClearanceRequirementFulfillment[] @relation("OfficeVerifier")
  institutionalOfficeVerifications InstitutionalClearanceItemFulfillment[] @relation("InstitutionalOfficeVerifier")
  preClearanceVerifications        StudentPreClearanceVerification[] @relation("PreClearanceStudent")
  preClearanceVerificationsGiven   StudentPreClearanceVerification[] @relation("PreClearanceVerifier")

  @@map("users")
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  role      Role
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@map("user_roles")
}

model Profile {
  id         String   @id
  email      String?
  fullName   String?
  studentId  String?
  yearLevel  String?
  course     String?
  address    String?
  age        Int?
  isArchived Boolean   @default(false)
  archivedAt DateTime?
  /// HR / employee record (optional)
  jobTitle           String?
  employeeDepartment String?
  hireDate           DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [id], references: [id], onDelete: Cascade)

  @@map("profiles")
}

/// In-person verification at faculty / sister offices before a student may request or submit clearance.
model StudentPreClearanceVerification {
  id               String           @id @default(cuid())
  studentId        String
  gate             PreClearanceGate
  verifiedAt       DateTime         @default(now())
  verifiedByUserId String
  notes            String?
  student          User             @relation("PreClearanceStudent", fields: [studentId], references: [id], onDelete: Cascade)
  verifiedBy       User             @relation("PreClearanceVerifier", fields: [verifiedByUserId], references: [id], onDelete: Restrict)

  @@unique([studentId, gate])
  @@index([studentId])
  @@map("student_pre_clearance_verifications")
}

model Signatory {
  id                     String        @id @default(cuid())
  name                   String
  position               String
  department             String
  email                  String
  isActive               Boolean       @default(true)
  isArchived             Boolean       @default(false)
  archivedAt             DateTime?
  userId                 String?       @unique
  signatoryGroup         SignatoryGroup @default(standard)
  authoritySequenceOrder Int?
  createdAt              DateTime      @default(now())
  /// Role for Section III: HRMDO / President lines (separate from row-level signatory for Section II)
  institutionalCertRole  InstitutionalCertificationRole @default(none)
  /// JSON: `{ "timezone": "Asia/Manila", "windows": [{ "dow": 1, "start": "09:00", "end": "17:00" }] }` (dow 0–6, Sun–Sat). Null = no enforcement.
  weeklyHoursJson        Json?

  user                   User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  signatures              ClearanceSignature[]
  defaultOrder            ClearanceDefaultSignatory?
  studentAssignments      StudentSignatoryAssignment[]
  stepNotes               StudentClearanceStepNote[]
  institutionalItems      InstitutionalClearanceItem[]
  institutionalOfficeDefs InstitutionalOfficeDefinition[]
  requirements            SignatoryRequirement[]

  @@map("signatories")
}

model SignatoryRequirement {
  id             Int              @id @default(autoincrement())
  signatoryId    String
  sortOrder      Int
  kind           RequirementKind
  label          String
  instructions   String?          @db.Text
  required       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  signatory    Signatory                       @relation(fields: [signatoryId], references: [id], onDelete: Cascade)
  fulfillments ClearanceRequirementFulfillment[]
  institutionalFulfillments InstitutionalClearanceItemFulfillment[]

  @@index([signatoryId])
  @@map("signatory_requirements")
}

model ClearanceRequirementFulfillment {
  id                       String    @id @default(cuid())
  clearanceSignatureId     String
  signatoryRequirementId   Int
  /// Array of `{ "blobUrl", "fileName" }` for document kind
  documentUrls             Json      @default("[]")
  physicalAttestedAt       DateTime?
  officeVerifiedAt         DateTime?
  officeVerifiedByUserId   String?
  officeVerificationNotes  String?   @db.Text

  signature    ClearanceSignature    @relation(fields: [clearanceSignatureId], references: [id], onDelete: Cascade)
  requirement  SignatoryRequirement  @relation(fields: [signatoryRequirementId], references: [id], onDelete: Cascade)
  officeVerifier User?               @relation("OfficeVerifier", fields: [officeVerifiedByUserId], references: [id], onDelete: SetNull)

  @@unique([clearanceSignatureId, signatoryRequirementId])
  @@index([clearanceSignatureId])
  @@map("clearance_requirement_fulfillments")
}

model ClearancePeriodExtension {
  id             String          @id @default(cuid())
  studentId      String
  extendsTo      DateTime
  reason         String          @db.Text
  status         ExtensionStatus @default(pending)
  reviewedById   String?
  reviewedAt     DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  student    User  @relation("ExtensionStudent", fields: [studentId], references: [id], onDelete: Cascade)
  reviewedBy User? @relation("ExtensionReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([studentId, status])
  @@map("clearance_period_extensions")
}

model ClearanceRequest {
  id          String         @id @default(cuid())
  studentId   String
  title       String
  description String?
  status      ClearanceStatus @default(pending)
  isArchived  Boolean        @default(false)
  archivedAt  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  student     User           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  signatures  ClearanceSignature[]
  files       ClearanceFile[]
  stepNotes   StudentClearanceStepNote[]

  @@map("clearance_requests")
}

model ClearanceSignature {
  id                     String         @id @default(cuid())
  clearanceRequestId     String
  signatoryId            String
  status                 SignatureStatus @default(pending)
  notes                  String?
  remarks                String?
  sequenceOrder          Int
  signedAt               DateTime?
  createdAt              DateTime       @default(now())
  signatoryGroup         SignatoryGroup  @default(standard)
  authoritySequenceOrder Int?

  clearanceRequest       ClearanceRequest @relation(fields: [clearanceRequestId], references: [id], onDelete: Cascade)
  signatory              Signatory        @relation(fields: [signatoryId], references: [id], onDelete: Cascade)
  requirementFulfillments ClearanceRequirementFulfillment[]

  @@index([clearanceRequestId])
  @@index([signatoryId])
  @@map("clearance_signatures")
}

model ClearanceFile {
  id                  String   @id @default(cuid())
  clearanceRequestId  String
  signatureId         String?
  fileName            String
  contentType         String?
  blobUrl             String
  uploadedAt          DateTime @default(now())

  clearanceRequest    ClearanceRequest @relation(fields: [clearanceRequestId], references: [id], onDelete: Cascade)

  @@index([clearanceRequestId])
  @@map("clearance_files")
}

model ClearanceDefaultSignatory {
  id           String   @id @default(cuid())
  signatoryId  String
  sequenceOrder Int

  signatory    Signatory @relation(fields: [signatoryId], references: [id], onDelete: Cascade)

  @@unique([signatoryId])
  @@map("clearance_default_signatories")
}

model StudentSignatoryAssignment {
  id            String        @id @default(cuid())
  studentId     String
  signatoryId   String
  sequenceOrder Int
  signatoryGroup SignatoryGroup @default(standard)

  student       User          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  signatory     Signatory     @relation(fields: [signatoryId], references: [id], onDelete: Cascade)

  @@unique([studentId, signatoryId])
  @@map("student_signatory_assignments")
}

model SystemSetting {
  key        String   @id
  valueJson  Json
  updatedAt  DateTime @updatedAt

  @@map("system_settings")
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  details   Json?
  userAgent String?
  ipAddress String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("activity_logs")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notifications")
}

model StudentClearanceStepNote {
  id                String   @id @default(cuid())
  clearanceRequestId String
  signatoryId        String
  note              String
  createdAt         DateTime @default(now())

  clearanceRequest  ClearanceRequest @relation(fields: [clearanceRequestId], references: [id], onDelete: Cascade)
  signatory         Signatory        @relation(fields: [signatoryId], references: [id], onDelete: Cascade)

  @@unique([clearanceRequestId, signatoryId])
  @@map("student_clearance_step_notes")
}

enum InstitutionalClearanceStatus {
  draft
  pending
  in_progress
  completed
  rejected
}

enum InstitutionalItemStatus {
  pending
  approved
  rejected
  waived
}

/// Staff / employee institutional (exit) clearance — separate from student clearances
model InstitutionalClearance {
  id               String                      @id @default(cuid())
  requesterId      String
  fullName         String
  position         String
  /// teaching | ntp
  employeeType     String?
  department       String
  dateOfSeparation DateTime?
  /// resignation | end_of_contract | transfer | other
  reasonCategory   String?
  /// Free text when reasonCategory is other, or additional notes
  reasonOtherDetails String?                  @db.Text
  reason           String?                     @db.Text
  /// cleared | not_cleared
  finalClearanceStatus  String?
  finalClearanceRemarks String?                 @db.Text
  status           InstitutionalClearanceStatus @default(pending)
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt

  requester User                          @relation("InstitutionalRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  items     InstitutionalClearanceItem[]
  approval  InstitutionalClearanceCertification?
  files     InstitutionalClearanceFile[]

  @@index([requesterId])
  @@index([status])
  @@map("institutional_clearance")
}

/// Configurable office rows for new institutional clearances (Section II template).
model InstitutionalOfficeDefinition {
  id              String   @id @default(cuid())
  sortOrder       Int
  departmentLabel String
  signatoryId     String?
  isArchived      Boolean  @default(false)
  archivedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  signatory Signatory? @relation(fields: [signatoryId], references: [id], onDelete: SetNull)

  @@index([sortOrder])
  @@map("institutional_office_definitions")
}

model InstitutionalClearanceFile {
  id                       String   @id @default(cuid())
  institutionalClearanceId String
  fileName                 String
  contentType              String?
  blobUrl                  String
  uploadedById             String
  isArchived               Boolean  @default(false)
  archivedAt               DateTime?
  createdAt                DateTime @default(now())

  clearance  InstitutionalClearance @relation(fields: [institutionalClearanceId], references: [id], onDelete: Cascade)
  uploadedBy User                   @relation("InstitutionalFileUploader", fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([institutionalClearanceId])
  @@map("institutional_clearance_files")
}

/// One row per office/department in the fixed employee clearance table (order matters).
model InstitutionalClearanceItem {
  id                       String                 @id @default(cuid())
  institutionalClearanceId String
  signatoryId              String?
  departmentLabel         String
  sortOrder                 Int
  status                   InstitutionalItemStatus @default(pending)
  submissionRemarks        String?                @db.Text
  remarks                  String?                @db.Text
  approverName             String?
  approvedAt               DateTime?
  approvedByUserId         String?

  clearance  InstitutionalClearance @relation(fields: [institutionalClearanceId], references: [id], onDelete: Cascade)
  signatory  Signatory?            @relation(fields: [signatoryId], references: [id], onDelete: SetNull)
  approvedBy User?                 @relation("InstitutionalItemApprover", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  requirementFulfillments InstitutionalClearanceItemFulfillment[]

  @@index([institutionalClearanceId])
  @@index([signatoryId])
  @@map("institutional_clearance_items")
}

model InstitutionalClearanceItemFulfillment {
  id                           String    @id @default(cuid())
  institutionalClearanceItemId String
  signatoryRequirementId       Int
  documentUrls                 Json      @default("[]")
  physicalAttestedAt           DateTime?
  officeVerifiedAt             DateTime?
  officeVerifiedByUserId       String?
  officeVerificationNotes      String?   @db.Text

  item         InstitutionalClearanceItem @relation(fields: [institutionalClearanceItemId], references: [id], onDelete: Cascade)
  requirement  SignatoryRequirement       @relation(fields: [signatoryRequirementId], references: [id], onDelete: Cascade)
  officeVerifier User?                    @relation("InstitutionalOfficeVerifier", fields: [officeVerifiedByUserId], references: [id], onDelete: SetNull)

  @@unique([institutionalClearanceItemId, signatoryRequirementId])
  @@index([institutionalClearanceItemId])
  @@map("institutional_clearance_item_fulfillments")
}

/// Certification block: prepared / verified / approved (separate 1:1 from main form)
model InstitutionalClearanceCertification {
  id                       String  @id @default(cuid())
  institutionalClearanceId String  @unique
  preparedByName           String?
  preparedAt               DateTime?
  verifiedByName           String?
  verifiedAt               DateTime?
  approvedByName           String?
  approvedAt               DateTime?

  clearance InstitutionalClearance @relation(fields: [institutionalClearanceId], references: [id], onDelete: Cascade)

  @@map("institutional_clearance_approvals")
}
