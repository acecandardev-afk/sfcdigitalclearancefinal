# --- Required (all environments) ---
# PostgreSQL connection string (Neon pooler URL recommended for Vercel serverless).
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# NextAuth session signing (generate: openssl rand -base64 32)
NEXTAUTH_SECRET="replace-with-a-long-random-secret"

# Public URL of the app (no trailing slash).
# Local: http://localhost:3000
# Vercel production: https://your-project.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# QR / public clearance verification tokens (can match NEXTAUTH_SECRET)
CLEARANCE_VERIFY_SECRET="replace-with-a-long-random-secret"

# --- Required on Vercel (file uploads; local disk is read-only) ---
# Create a Blob store in Vercel → Storage → Blob, then link to the project.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxx"

# --- Optional ---
# Canonical public URL for links (defaults to NEXTAUTH_URL or VERCEL_URL on Vercel).
# NEXT_PUBLIC_APP_URL="https://your-project.vercel.app"

# --- Seed only (local / CI — not needed for Vercel runtime) ---
# SEED_ADMIN_EMAIL="admin@example.com"
# SEED_ADMIN_PASSWORD="change-this-password"
# SEED_ADMIN_FULL_NAME="Administrator"
