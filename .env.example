# Supabase (required for app)
VITE_SUPABASE_URL=https://your-project.supabase.co
# Prefer legacy anon JWT (starts with eyJ...) from Project Settings → API if you see "Invalid JWT" with Edge Functions.
VITE_SUPABASE_ANON_KEY=
# Or use the new publishable key (sb_publishable_...):
VITE_SUPABASE_PUBLISHABLE_KEY=

# Required for npm run seed (creates test users)
# Get from: Supabase Dashboard → Project Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Edge Function auto-approve-stale-signatures: set in Supabase Dashboard → Edge Functions → Secrets as CRON_SECRET.
# Scheduled invocations must send header: x-cron-secret: <same value>
